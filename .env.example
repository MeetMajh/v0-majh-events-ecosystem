# MAJH EVENTS — environment variable template
# Copy to .env.local for development. Fill in real values for any var marked
# "required". Optional vars can be left blank to disable the related feature.
# Source of truth for this list: ralph-dev/ENV.md

# ---------------------------------------------------------------------------
# Supabase (Postgres + RLS)            required
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection (scripts/ only)            optional
POSTGRES_URL=

# ---------------------------------------------------------------------------
# Stripe                               required
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# Mux (live + VOD)                     required
# ---------------------------------------------------------------------------
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Webhook signing secret (required in prod)
MUX_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# LiveKit (studio rooms)               required
# ---------------------------------------------------------------------------
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# ---------------------------------------------------------------------------
# RTMP / custom streaming              optional
# ---------------------------------------------------------------------------
RTMP_ENABLED=
RTMP_SERVER_URL=
RTMP_PLAYBACK_URL=

# ---------------------------------------------------------------------------
# Third-party streaming APIs           optional
# ---------------------------------------------------------------------------
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
YOUTUBE_API_KEY=
TOPDECK_API_KEY=

# ---------------------------------------------------------------------------
# Email (Resend)                       required
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Cron / job auth                      required
# ---------------------------------------------------------------------------
# Bearer token expected by every app/api/cron/* route
CRON_SECRET=

# ---------------------------------------------------------------------------
# Admin / AI                           required + optional
# ---------------------------------------------------------------------------
# Comma-separated admin emails (required)
ADMIN_EMAILS=
# Claude API key for /api/run (optional)
CLAUDE_API_KEY=
# External two-tower ML service (optional)
ML_SERVICE_URL=

# ---------------------------------------------------------------------------
# URL / deployment                     required
# ---------------------------------------------------------------------------
# Canonical app origin (Stripe success_url, share links, transactional emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Alt origin used by legacy login/checkout paths
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Dev-only OAuth redirect override (optional)
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# ---------------------------------------------------------------------------
# Pre-deploy tooling (CI only)         optional
# ---------------------------------------------------------------------------
PREDEPLOY_CHECK_URL=
PREDEPLOY_API_KEY=
SKIP_PREDEPLOY_CHECK=

# ---------------------------------------------------------------------------
# Vercel-provided — do NOT set here. Listed for documentation only.
#   VERCEL_URL, VERCEL_ENV, VERCEL_GIT_COMMIT_SHA, VERCEL_GIT_COMMIT_REF, NODE_ENV
# ---------------------------------------------------------------------------
